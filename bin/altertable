# :command.parse_requirements
parse_requirements() {
  local key

  # :command.fixed_flags_filter
  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in
      --version | -v)
        version_command
        exit
        ;;

      --help | -h)
        long_usage=yes
        altertable_usage
        exit
        ;;

      # :flag.case
      --debug)

        # :flag.case_no_arg
        args['--debug']=1
        shift
        ;;

      *)
        break
        ;;

    esac
  done

  # :command.environment_variables_filter

  env_var_names+=("ALTERTABLE_LAKEHOUSE_USERNAME")
  env_var_names+=("ALTERTABLE_LAKEHOUSE_PASSWORD")
  env_var_names+=("ALTERTABLE_BASIC_AUTH_TOKEN")
  env_var_names+=("ALTERTABLE_API_BASE")

  # :command.command_filter
  action=${1:-}

  case $action in
    -*) ;;

    query)
      action="query"
      shift
      altertable_query_parse_requirements "$@"
      shift $#
      ;;

    validate)
      action="validate"
      shift
      altertable_validate_parse_requirements "$@"
      shift $#
      ;;

    append)
      action="append"
      shift
      altertable_append_parse_requirements "$@"
      shift $#
      ;;

    upload)
      action="upload"
      shift
      altertable_upload_parse_requirements "$@"
      shift $#
      ;;

    get-query)
      action="get-query"
      shift
      altertable_get_query_parse_requirements "$@"
      shift $#
      ;;

    cancel)
      action="cancel"
      shift
      altertable_cancel_parse_requirements "$@"
      shift $#
      ;;

    # :command.command_fallback
    "")
      altertable_usage >&2
      exit 1
      ;;

    *)
      printf "invalid command: %s\n" "$action" >&2
      exit 1
      ;;

  esac

  # :command.parse_requirements_while
  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in

      -?*)
        printf "invalid option: %s\n" "$key" >&2
        exit 1
        ;;

      *)
        # :command.parse_requirements_case
        # :command.parse_requirements_case_simple
        printf "invalid argument: %s\n" "$key" >&2
        exit 1

        ;;

    esac
  done

}

# :command.parse_requirements
altertable_query_parse_requirements() {
  local key

  # :command.fixed_flags_filter
  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in
      --help | -h)
        long_usage=yes
        altertable_query_usage
        exit
        ;;

      *)
        break
        ;;

    esac
  done

  # :command.command_filter
  action="query"

  # :command.parse_requirements_while
  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in
      # :flag.case
      --statement)

        # :flag.case_arg
        if [[ -n ${2+x} ]]; then
          args['--statement']="$2"
          shift
          shift
        else
          printf "%s\n" "--statement requires an argument: --statement SQL" >&2
          exit 1
        fi
        ;;

      # :flag.case
      --format)

        # :flag.case_arg
        if [[ -n ${2+x} ]]; then
          args['--format']="$2"
          shift
          shift
        else
          printf "%s\n" "--format requires an argument: --format FMT" >&2
          exit 1
        fi
        ;;

      # :flag.case
      --query-id)

        # :flag.case_arg
        if [[ -n ${2+x} ]]; then
          args['--query-id']="$2"
          shift
          shift
        else
          printf "%s\n" "--query-id requires an argument: --query-id UUID" >&2
          exit 1
        fi
        ;;

      # :flag.case
      --session-id)

        # :flag.case_arg
        if [[ -n ${2+x} ]]; then
          args['--session-id']="$2"
          shift
          shift
        else
          printf "%s\n" "--session-id requires an argument: --session-id UUID" >&2
          exit 1
        fi
        ;;

      # :flag.case
      --debug)

        # :flag.case_no_arg
        args['--debug']=1
        shift
        ;;

      -?*)
        printf "invalid option: %s\n" "$key" >&2
        exit 1
        ;;

      *)
        # :command.parse_requirements_case
        # :command.parse_requirements_case_simple
        printf "invalid argument: %s\n" "$key" >&2
        exit 1

        ;;

    esac
  done

  # :command.required_flags_filter
  if [[ -z ${args['--statement']+x} ]]; then
    printf "missing required flag: --statement SQL\n" >&2
    exit 1
  fi

  # :command.default_assignments
  [[ -n ${args['--format']:-} ]] || args['--format']="json"

}


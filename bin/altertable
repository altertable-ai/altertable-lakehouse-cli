          shift
        else
          printf "%s\n" "--schema requires an argument: --schema NAME" >&2
          exit 1
        fi
        ;;

      # :flag.case
      --table)

        # :flag.case_arg
        if [[ -n ${2+x} ]]; then
          args['--table']="$2"
          shift
          shift
        else
          printf "%s\n" "--table requires an argument: --table NAME" >&2
          exit 1
        fi
        ;;

      # :flag.case
      --data)

        # :flag.case_arg
        if [[ -n ${2+x} ]]; then
          args['--data']="$2"
          shift
          shift
        else
          printf "%s\n" "--data requires an argument: --data JSON" >&2
          exit 1
        fi
        ;;

      # :flag.case
      --debug)

        # :flag.case_no_arg
        args['--debug']=1
        shift
        ;;

      -?*)
        printf "invalid option: %s\n" "$key" >&2
        exit 1
        ;;

      *)
        # :command.parse_requirements_case
        # :command.parse_requirements_case_simple
        printf "invalid argument: %s\n" "$key" >&2
        exit 1

        ;;

    esac
  done

  # :command.required_flags_filter
  if [[ -z ${args['--catalog']+x} ]]; then
    printf "missing required flag: --catalog NAME\n" >&2
    exit 1
  fi
  if [[ -z ${args['--schema']+x} ]]; then
    printf "missing required flag: --schema NAME\n" >&2
    exit 1
  fi
  if [[ -z ${args['--table']+x} ]]; then
    printf "missing required flag: --table NAME\n" >&2
    exit 1
  fi
  if [[ -z ${args['--data']+x} ]]; then
    printf "missing required flag: --data JSON\n" >&2
    exit 1
  fi

}

# :command.parse_requirements
altertable_upload_parse_requirements() {
  local key

  # :command.fixed_flags_filter
  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in
      --help | -h)
        long_usage=yes
        altertable_upload_usage
        exit
        ;;

      *)
        break
        ;;

    esac
  done

  # :command.command_filter
  action="upload"

  # :command.parse_requirements_while
  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in
      # :flag.case
      --catalog)

        # :flag.case_arg
        if [[ -n ${2+x} ]]; then
          args['--catalog']="$2"
          shift
          shift
        else
          printf "%s\n" "--catalog requires an argument: --catalog NAME" >&2
          exit 1
        fi
        ;;

      # :flag.case
      --schema)

        # :flag.case_arg
        if [[ -n ${2+x} ]]; then
          args['--schema']="$2"
          shift
          shift
        else
          printf "%s\n" "--schema requires an argument: --schema NAME" >&2
          exit 1
        fi
        ;;

      # :flag.case
      --table)

        # :flag.case_arg
        if [[ -n ${2+x} ]]; then
          args['--table']="$2"
          shift
          shift
        else
          printf "%s\n" "--table requires an argument: --table NAME" >&2
          exit 1
        fi
        ;;

      # :flag.case
      --format)

        # :flag.case_arg
        if [[ -n ${2+x} ]]; then
          args['--format']="$2"
          shift
          shift
        else
          printf "%s\n" "--format requires an argument: --format FMT" >&2
          exit 1
        fi
        ;;

      # :flag.case
      --mode)

        # :flag.case_arg
        if [[ -n ${2+x} ]]; then
          args['--mode']="$2"
          shift
          shift
        else
          printf "%s\n" "--mode requires an argument: --mode MODE" >&2
          exit 1
        fi
        ;;

      # :flag.case
      --primary-key)

        # :flag.case_arg
        if [[ -n ${2+x} ]]; then
          args['--primary-key']="$2"
          shift
          shift
        else
          printf "%s\n" "--primary-key requires an argument: --primary-key COLS" >&2
          exit 1
        fi
        ;;

      # :flag.case
      --file)

        # :flag.case_arg
        if [[ -n ${2+x} ]]; then
          args['--file']="$2"
          shift
          shift
        else
          printf "%s\n" "--file requires an argument: --file PATH" >&2
          exit 1
        fi
        ;;

      # :flag.case
      --debug)

        # :flag.case_no_arg
        args['--debug']=1
        shift
        ;;

      -?*)
        printf "invalid option: %s\n" "$key" >&2
        exit 1
        ;;

      *)
        # :command.parse_requirements_case
        # :command.parse_requirements_case_simple
        printf "invalid argument: %s\n" "$key" >&2
        exit 1

        ;;

    esac
  done

  # :command.required_flags_filter
  if [[ -z ${args['--catalog']+x} ]]; then
    printf "missing required flag: --catalog NAME\n" >&2
    exit 1
  fi
  if [[ -z ${args['--schema']+x} ]]; then
    printf "missing required flag: --schema NAME\n" >&2
    exit 1
  fi
  if [[ -z ${args['--table']+x} ]]; then
    printf "missing required flag: --table NAME\n" >&2
    exit 1
  fi
  if [[ -z ${args['--format']+x} ]]; then
    printf "missing required flag: --format FMT\n" >&2
    exit 1
  fi
  if [[ -z ${args['--mode']+x} ]]; then
    printf "missing required flag: --mode MODE\n" >&2
    exit 1
  fi
  if [[ -z ${args['--file']+x} ]]; then
    printf "missing required flag: --file PATH\n" >&2
    exit 1
  fi

}

# :command.parse_requirements
altertable_get_query_parse_requirements() {
  local key

  # :command.fixed_flags_filter
  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in
      --help | -h)
        long_usage=yes
        altertable_get_query_usage
        exit
        ;;

      *)
        break
        ;;

    esac
  done

  # :command.command_filter
  action="get-query"

  # :command.parse_requirements_while
  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in
      # :flag.case
      --debug)

        # :flag.case_no_arg
        args['--debug']=1
        shift
        ;;

      -?*)
        printf "invalid option: %s\n" "$key" >&2
        exit 1
        ;;

      *)
        # :command.parse_requirements_case
        # :command.parse_requirements_case_simple
        # :argument.case
        if [[ -z ${args['query_uuid']+x} ]]; then
          args['query_uuid']=$1
          shift
        else
          printf "invalid argument: %s\n" "$key" >&2
          exit 1
        fi

        ;;

    esac
  done

  # :command.required_args_filter
  if [[ -z ${args['query_uuid']+x} ]]; then
    printf "missing required argument: QUERY_UUID\nusage: altertable get-query QUERY_UUID [OPTIONS]\n" >&2

    exit 1
  fi

}

# :command.parse_requirements
altertable_cancel_parse_requirements() {
  local key

  # :command.fixed_flags_filter
  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in
      --help | -h)
        long_usage=yes
        altertable_cancel_usage
        exit
        ;;

      *)
        break
        ;;

    esac
  done

  # :command.command_filter
  action="cancel"

  # :command.parse_requirements_while
  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in
      # :flag.case
      --query-id)

        # :flag.case_arg
        if [[ -n ${2+x} ]]; then
          args['--query-id']="$2"
          shift
          shift
        else
          printf "%s\n" "--query-id requires an argument: --query-id UUID" >&2
          exit 1
        fi
        ;;

      # :flag.case
      --session-id)

        # :flag.case_arg
        if [[ -n ${2+x} ]]; then
          args['--session-id']="$2"
          shift
          shift
        else
          printf "%s\n" "--session-id requires an argument: --session-id UUID" >&2
          exit 1
        fi
        ;;

      # :flag.case
      --debug)

        # :flag.case_no_arg
        args['--debug']=1
        shift
        ;;

      -?*)
        printf "invalid option: %s\n" "$key" >&2
        exit 1
        ;;

      *)
        # :command.parse_requirements_case
        # :command.parse_requirements_case_simple
        printf "invalid argument: %s\n" "$key" >&2
        exit 1

        ;;

    esac
  done

  # :command.required_flags_filter
  if [[ -z ${args['--query-id']+x} ]]; then
    printf "missing required flag: --query-id UUID\n" >&2
    exit 1
  fi
  if [[ -z ${args['--session-id']+x} ]]; then
    printf "missing required flag: --session-id UUID\n" >&2
    exit 1
  fi

}

# :command.initialize
initialize() {
  declare -g version="0.4.0"
  set -e

}

# :command.run
run() {
  # :command.globals
  declare -g long_usage=''
  declare -g -A args=()
  declare -g -A deps=()
  declare -g -a env_var_names=()
  declare -g -a input=()

  normalize_input "$@"
  parse_requirements "${input[@]}"

  case "$action" in
    "query") altertable_query_command ;;
    "validate") altertable_validate_command ;;
    "append") altertable_append_command ;;
    "upload") altertable_upload_command ;;
    "get-query") altertable_get_query_command ;;
    "cancel") altertable_cancel_command ;;
  esac
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  # :command.start
  command_line_args=("$@")
  initialize
  run "${command_line_args[@]}"
fi

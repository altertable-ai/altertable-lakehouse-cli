# :command.usage
altertable_usage() {
  printf "altertable - A Bash-based CLI for the Altertable Lakehouse API.\n\n"

  printf "%s\n" "Usage:"
  printf "  altertable [OPTIONS] COMMAND\n"
  printf "  altertable [COMMAND] --help | -h\n"
  printf "  altertable --version | -v\n"
  echo
  # :command.usage_commands
  printf "%s\n" "Commands:"
  printf "  %s   Run a SQL query against the lakehouse.\n" "query    "
  printf "  %s   Validate a SQL statement without executing it.\n" "validate "
  printf "  %s   Append JSON rows to a table.\n" "append   "
  printf "  %s   Upload a file to create or update a table.\n" "upload   "
  printf "  %s   Fetch metadata for a completed or running query.\n" "get-query"
  printf "  %s   Cancel a running query.\n" "cancel   "
  echo

  # :command.long_usage
  if [[ -n "$long_usage" ]]; then
    # :command.usage_options
    printf "%s\n" "Global Options:"

    # :command.usage_flags
    # :flag.usage
    printf "  %s\n" "--debug"
    printf "    Enable debug output\n"
    echo

    # :command.usage_fixed_flags
    printf "  %s\n" "--help, -h"
    printf "    Show this help\n"
    echo
    printf "  %s\n" "--version, -v"
    printf "    Show version number\n"
    echo

    # :command.usage_environment_variables
    printf "%s\n" "Environment Variables:"

    # :environment_variable.usage
    printf "  %s\n" "ALTERTABLE_LAKEHOUSE_USERNAME"
    printf "    Lakehouse Username\n"
    echo

    # :environment_variable.usage
    printf "  %s\n" "ALTERTABLE_LAKEHOUSE_PASSWORD"
    printf "    Lakehouse Password\n"
    echo

    # :environment_variable.usage
    printf "  %s\n" "ALTERTABLE_BASIC_AUTH_TOKEN"
    printf "    Pre-encoded Basic Auth Token (optional)\n"
    echo

    # :environment_variable.usage
    printf "  %s\n" "ALTERTABLE_API_BASE"
    printf "    API Base URL (default: https://api.altertable.ai)\n"
    echo

  fi
}

